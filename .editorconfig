root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4

[*.php]
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{css}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 4

[*.{js,ts}]
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

[composer.json]
indent_size = 4
