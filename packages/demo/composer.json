{
    "name": "ducrot/twigcn-demo",
    "description": "Demo application for TwigcnBundle",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ducrot/twigcn-bundle": "@dev",
        "pentatrion/vite-bundle": "^8.0",
        "symfony/asset": "~7.4.0",
        "symfony/console": "~7.4.0",
        "symfony/dotenv": "*",
        "symfony/flex": "^2",
        "symfony/framework-bundle": "~7.4.0",
        "symfony/runtime": "~7.4.0",
        "symfony/twig-bundle": "~7.4.0",
        "symfony/ux-icons": "^2.18",
        "symfony/ux-twig-component": "^2.18",
        "symfony/yaml": "~7.4.0"
    },
    "require-dev": {
        "symfony/debug-bundle": "~7.4.0",
        "symfony/stopwatch": "~7.4.0",
        "symfony/web-profiler-bundle": "~7.4.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../bundle",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        }
    }
}
