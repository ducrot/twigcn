{% extends 'showcase/base.html.twig' %}

{% block title %}Sidebar - Component Showcase{% endblock %}

{% block showcase_content %}
<div class="flex flex-col gap-8">
    <header>
        <h1 class="text-3xl font-bold tracking-tight">Sidebar</h1>
        <p class="text-muted-foreground mt-2">A composable, themeable and customizable sidebar component.</p>
    </header>

    {# Basic Example #}
    <section class="card">
        <header>
            <h2 class="text-lg font-semibold">Basic Sidebar</h2>
        </header>
        <section>
            <div class="border rounded-lg overflow-hidden h-[400px] flex">
                <twig:Twigcn:Sidebar class="w-64 border-r bg-background">
                    <twig:Twigcn:SidebarHeader class="p-4 border-b">
                        <h3 class="font-semibold">Application</h3>
                    </twig:Twigcn:SidebarHeader>
                    <twig:Twigcn:SidebarContent class="p-2">
                        <twig:Twigcn:SidebarGroup>
                            <twig:Twigcn:SidebarGroupLabel class="px-2 py-1 text-xs text-muted-foreground">Menu</twig:Twigcn:SidebarGroupLabel>
                            <twig:Twigcn:SidebarGroupContent>
                                <twig:Twigcn:SidebarMenu>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#" :active="true">
                                            <twig:ux:icon name="lucide:home" class="w-4 h-4 mr-2" />
                                            Home
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:inbox" class="w-4 h-4 mr-2" />
                                            Inbox
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:calendar" class="w-4 h-4 mr-2" />
                                            Calendar
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:search" class="w-4 h-4 mr-2" />
                                            Search
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                </twig:Twigcn:SidebarMenu>
                            </twig:Twigcn:SidebarGroupContent>
                        </twig:Twigcn:SidebarGroup>
                    </twig:Twigcn:SidebarContent>
                    <twig:Twigcn:SidebarFooter class="p-4 border-t mt-auto">
                        <div class="flex items-center gap-2 text-sm">
                            <twig:Twigcn:Avatar src="https://github.com/shadcn.png" alt="User" size="sm" />
                            <span>John Doe</span>
                        </div>
                    </twig:Twigcn:SidebarFooter>
                </twig:Twigcn:Sidebar>
                <div class="flex-1 p-4">
                    <p class="text-muted-foreground">Main content area</p>
                </div>
            </div>
        </section>
    </section>

    {# With Groups #}
    <section class="card">
        <header>
            <h2 class="text-lg font-semibold">With Multiple Groups</h2>
        </header>
        <section>
            <div class="border rounded-lg overflow-hidden h-[500px] flex">
                <twig:Twigcn:Sidebar class="w-64 border-r bg-background">
                    <twig:Twigcn:SidebarHeader class="p-4 border-b">
                        <div class="flex items-center gap-2">
                            <twig:ux:icon name="lucide:package" class="w-6 h-6" />
                            <span class="font-semibold">Acme Inc</span>
                        </div>
                    </twig:Twigcn:SidebarHeader>
                    <twig:Twigcn:SidebarContent class="p-2">
                        <twig:Twigcn:SidebarGroup>
                            <twig:Twigcn:SidebarGroupLabel class="px-2 py-1 text-xs text-muted-foreground">Platform</twig:Twigcn:SidebarGroupLabel>
                            <twig:Twigcn:SidebarGroupContent>
                                <twig:Twigcn:SidebarMenu>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:layout-dashboard" class="w-4 h-4 mr-2" />
                                            Dashboard
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:bar-chart-3" class="w-4 h-4 mr-2" />
                                            Analytics
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:file-text" class="w-4 h-4 mr-2" />
                                            Reports
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                </twig:Twigcn:SidebarMenu>
                            </twig:Twigcn:SidebarGroupContent>
                        </twig:Twigcn:SidebarGroup>

                        <twig:Twigcn:SidebarGroup>
                            <twig:Twigcn:SidebarGroupLabel class="px-2 py-1 text-xs text-muted-foreground">Projects</twig:Twigcn:SidebarGroupLabel>
                            <twig:Twigcn:SidebarGroupContent>
                                <twig:Twigcn:SidebarMenu>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:folder" class="w-4 h-4 mr-2" />
                                            Project Alpha
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:folder" class="w-4 h-4 mr-2" />
                                            Project Beta
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:folder" class="w-4 h-4 mr-2" />
                                            Project Gamma
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                </twig:Twigcn:SidebarMenu>
                            </twig:Twigcn:SidebarGroupContent>
                        </twig:Twigcn:SidebarGroup>

                        <twig:Twigcn:SidebarGroup>
                            <twig:Twigcn:SidebarGroupLabel class="px-2 py-1 text-xs text-muted-foreground">Settings</twig:Twigcn:SidebarGroupLabel>
                            <twig:Twigcn:SidebarGroupContent>
                                <twig:Twigcn:SidebarMenu>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:settings" class="w-4 h-4 mr-2" />
                                            General
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:users" class="w-4 h-4 mr-2" />
                                            Team
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:credit-card" class="w-4 h-4 mr-2" />
                                            Billing
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                </twig:Twigcn:SidebarMenu>
                            </twig:Twigcn:SidebarGroupContent>
                        </twig:Twigcn:SidebarGroup>
                    </twig:Twigcn:SidebarContent>
                </twig:Twigcn:Sidebar>
                <div class="flex-1 p-4">
                    <p class="text-muted-foreground">Main content area</p>
                </div>
            </div>
        </section>
    </section>

    {# Component Structure #}
    <section class="card">
        <header>
            <h2 class="text-lg font-semibold">Usage</h2>
        </header>
        <section class="prose prose-sm max-w-none">
            <pre class="bg-muted p-4 rounded-lg overflow-x-auto"><code>&lt;twig:Sidebar&gt;
    &lt;twig:SidebarHeader&gt;...&lt;/twig:SidebarHeader&gt;
    &lt;twig:SidebarContent&gt;
        &lt;twig:SidebarGroup&gt;
            &lt;twig:SidebarGroupLabel&gt;...&lt;/twig:SidebarGroupLabel&gt;
            &lt;twig:SidebarGroupContent&gt;
                &lt;twig:SidebarMenu&gt;
                    &lt;twig:SidebarMenuItem&gt;
                        &lt;twig:SidebarMenuButton href="..."&gt;
                            ...
                        &lt;/twig:SidebarMenuButton&gt;
                    &lt;/twig:SidebarMenuItem&gt;
                &lt;/twig:SidebarMenu&gt;
            &lt;/twig:SidebarGroupContent&gt;
        &lt;/twig:SidebarGroup&gt;
    &lt;/twig:SidebarContent&gt;
    &lt;twig:SidebarFooter&gt;...&lt;/twig:SidebarFooter&gt;
&lt;/twig:Sidebar&gt;</code></pre>
        </section>
    </section>
</div>
{% endblock %}
