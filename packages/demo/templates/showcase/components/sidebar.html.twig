{% extends 'showcase/base.html.twig' %}

{% block title %}Sidebar - Component Showcase{% endblock %}

{% block showcase_content %}
<div class="flex flex-col gap-8">
    <header>
        <h1 class="text-3xl font-bold tracking-tight">Sidebar</h1>
        <p class="text-muted-foreground mt-2">A composable, themeable and customizable sidebar component.</p>
    </header>

    {# Basic Example #}
    <section class="card">
        <header>
            <h2 class="text-lg font-semibold">Basic Sidebar</h2>
        </header>
        <section>
            <div class="border rounded-lg overflow-hidden h-[400px] flex">
                <twig:Twigcn:Sidebar variant="inline">
                    <twig:Twigcn:SidebarHeader>
                        <span class="font-semibold">Application</span>
                    </twig:Twigcn:SidebarHeader>
                    <twig:Twigcn:SidebarContent>
                        <twig:Twigcn:SidebarGroup>
                            <twig:Twigcn:SidebarGroupLabel>Menu</twig:Twigcn:SidebarGroupLabel>
                            <twig:Twigcn:SidebarGroupContent>
                                <twig:Twigcn:SidebarMenu>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#" :active="true">
                                            <twig:ux:icon name="lucide:home" />
                                            <span>Home</span>
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:inbox" />
                                            <span>Inbox</span>
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:calendar" />
                                            <span>Calendar</span>
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:search" />
                                            <span>Search</span>
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                </twig:Twigcn:SidebarMenu>
                            </twig:Twigcn:SidebarGroupContent>
                        </twig:Twigcn:SidebarGroup>
                    </twig:Twigcn:SidebarContent>
                    <twig:Twigcn:SidebarFooter>
                        <div class="flex items-center gap-2 text-sm">
                            <twig:Twigcn:Avatar src="https://github.com/shadcn.png" alt="User" size="sm" />
                            <span>John Doe</span>
                        </div>
                    </twig:Twigcn:SidebarFooter>
                </twig:Twigcn:Sidebar>
                <twig:Twigcn:SidebarInset class="p-4">
                    <p class="text-muted-foreground">Main content area</p>
                </twig:Twigcn:SidebarInset>
            </div>
        </section>
    </section>

    {# With Groups #}
    <section class="card">
        <header>
            <h2 class="text-lg font-semibold">With Multiple Groups</h2>
        </header>
        <section>
            <div class="border rounded-lg overflow-hidden h-[500px] flex">
                <twig:Twigcn:Sidebar variant="inline">
                    <twig:Twigcn:SidebarHeader>
                        <div class="flex items-center gap-2">
                            <twig:ux:icon name="lucide:package" class="size-6" />
                            <span class="font-semibold">Acme Inc</span>
                        </div>
                    </twig:Twigcn:SidebarHeader>
                    <twig:Twigcn:SidebarContent>
                        <twig:Twigcn:SidebarGroup>
                            <twig:Twigcn:SidebarGroupLabel>Platform</twig:Twigcn:SidebarGroupLabel>
                            <twig:Twigcn:SidebarGroupContent>
                                <twig:Twigcn:SidebarMenu>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:layout-dashboard" />
                                            <span>Dashboard</span>
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:bar-chart-3" />
                                            <span>Analytics</span>
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:file-text" />
                                            <span>Reports</span>
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                </twig:Twigcn:SidebarMenu>
                            </twig:Twigcn:SidebarGroupContent>
                        </twig:Twigcn:SidebarGroup>

                        <twig:Twigcn:SidebarGroup>
                            <twig:Twigcn:SidebarGroupLabel>Projects</twig:Twigcn:SidebarGroupLabel>
                            <twig:Twigcn:SidebarGroupContent>
                                <twig:Twigcn:SidebarMenu>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:folder" />
                                            <span>Project Alpha</span>
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:folder" />
                                            <span>Project Beta</span>
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:folder" />
                                            <span>Project Gamma</span>
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                </twig:Twigcn:SidebarMenu>
                            </twig:Twigcn:SidebarGroupContent>
                        </twig:Twigcn:SidebarGroup>

                        <twig:Twigcn:SidebarGroup>
                            <twig:Twigcn:SidebarGroupLabel>Settings</twig:Twigcn:SidebarGroupLabel>
                            <twig:Twigcn:SidebarGroupContent>
                                <twig:Twigcn:SidebarMenu>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:settings" />
                                            <span>General</span>
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:users" />
                                            <span>Team</span>
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:credit-card" />
                                            <span>Billing</span>
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                </twig:Twigcn:SidebarMenu>
                            </twig:Twigcn:SidebarGroupContent>
                        </twig:Twigcn:SidebarGroup>
                    </twig:Twigcn:SidebarContent>
                </twig:Twigcn:Sidebar>
                <twig:Twigcn:SidebarInset class="p-4">
                    <p class="text-muted-foreground">Main content area</p>
                </twig:Twigcn:SidebarInset>
            </div>
        </section>
    </section>

    {# With Trigger & Collapsible #}
    <section class="card">
        <header>
            <h2 class="text-lg font-semibold">With Trigger & Collapsible</h2>
            <p class="text-sm text-muted-foreground mt-1">Click the trigger or press <kbd class="kbd">⌘ B</kbd> / <kbd class="kbd">Ctrl B</kbd> to toggle.</p>
        </header>
        <section>
            <div class="border rounded-lg overflow-hidden h-[400px] flex">
                <twig:Twigcn:Sidebar id="trigger-demo-sidebar" variant="inline" collapsible="offcanvas">
                    <twig:Twigcn:SidebarHeader>
                        <span class="font-semibold">My App</span>
                    </twig:Twigcn:SidebarHeader>
                    <twig:Twigcn:SidebarContent>
                        <twig:Twigcn:SidebarGroup>
                            <twig:Twigcn:SidebarGroupLabel>Navigation</twig:Twigcn:SidebarGroupLabel>
                            <twig:Twigcn:SidebarGroupContent>
                                <twig:Twigcn:SidebarMenu>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#" :active="true">
                                            <twig:ux:icon name="lucide:home" />
                                            <span>Home</span>
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                    <twig:Twigcn:SidebarMenuItem>
                                        <twig:Twigcn:SidebarMenuButton href="#">
                                            <twig:ux:icon name="lucide:bell" />
                                            <span>Notifications</span>
                                        </twig:Twigcn:SidebarMenuButton>
                                    </twig:Twigcn:SidebarMenuItem>
                                </twig:Twigcn:SidebarMenu>
                            </twig:Twigcn:SidebarGroupContent>
                        </twig:Twigcn:SidebarGroup>
                    </twig:Twigcn:SidebarContent>
                </twig:Twigcn:Sidebar>
                <twig:Twigcn:SidebarInset class="p-4">
                    <div class="flex items-center gap-3 border-b pb-3 mb-3">
                        <twig:Twigcn:SidebarTrigger for="#trigger-demo-sidebar" />
                        <span class="text-sm text-muted-foreground">Toggle sidebar</span>
                    </div>
                    <p class="text-muted-foreground">Main content area</p>
                </twig:Twigcn:SidebarInset>
            </div>
        </section>
    </section>

    {# Component Structure #}
    <section class="card">
        <header>
            <h2 class="text-lg font-semibold">Usage</h2>
        </header>
        <section class="prose prose-sm max-w-none">
            <pre class="bg-muted p-4 rounded-lg overflow-x-auto"><code>&lt;twig:Sidebar variant="inline" collapsible="offcanvas"&gt;
    &lt;twig:SidebarHeader&gt;...&lt;/twig:SidebarHeader&gt;
    &lt;twig:SidebarContent&gt;
        &lt;twig:SidebarGroup&gt;
            &lt;twig:SidebarGroupLabel&gt;...&lt;/twig:SidebarGroupLabel&gt;
            &lt;twig:SidebarGroupContent&gt;
                &lt;twig:SidebarMenu&gt;
                    &lt;twig:SidebarMenuItem&gt;
                        &lt;twig:SidebarMenuButton href="..." :active="true"&gt;
                            ...
                        &lt;/twig:SidebarMenuButton&gt;
                    &lt;/twig:SidebarMenuItem&gt;
                &lt;/twig:SidebarMenu&gt;
            &lt;/twig:SidebarGroupContent&gt;
        &lt;/twig:SidebarGroup&gt;
    &lt;/twig:SidebarContent&gt;
    &lt;twig:SidebarFooter&gt;...&lt;/twig:SidebarFooter&gt;
&lt;/twig:Sidebar&gt;
&lt;twig:SidebarInset&gt;
    &lt;twig:SidebarTrigger /&gt;
    Main content
&lt;/twig:SidebarInset&gt;</code></pre>
        </section>
    </section>
</div>
{% endblock %}
