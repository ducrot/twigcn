{% extends 'showcase/base.html.twig' %}

{% block title %}Tooltip - Component Showcase{% endblock %}

{% block showcase_content %}
<div class="flex flex-col gap-8">
    <header>
        <h1 class="text-3xl font-bold tracking-tight">Tooltip</h1>
        <p class="text-muted-foreground mt-2">
            A popup that displays information related to an element on hover.
        </p>
    </header>

    {# Default #}
    <section class="card">
        <header>
            <h2 class="text-lg font-semibold">Default</h2>
        </header>
        <section>
            <twig:Twigcn:Tooltip text="Add to library">
                <twig:Twigcn:Button variant="outline">Hover me</twig:Twigcn:Button>
            </twig:Twigcn:Tooltip>
        </section>
    </section>

    {# Positions #}
    <section class="card">
        <header>
            <h2 class="text-lg font-semibold">Positions</h2>
        </header>
        <section class="flex flex-wrap gap-4 py-8">
            <twig:Twigcn:Tooltip text="Tooltip on top" side="top">
                <twig:Twigcn:Button variant="outline">Top</twig:Twigcn:Button>
            </twig:Twigcn:Tooltip>
            <twig:Twigcn:Tooltip text="Tooltip on bottom" side="bottom">
                <twig:Twigcn:Button variant="outline">Bottom</twig:Twigcn:Button>
            </twig:Twigcn:Tooltip>
            <twig:Twigcn:Tooltip text="Tooltip on left" side="left">
                <twig:Twigcn:Button variant="outline">Left</twig:Twigcn:Button>
            </twig:Twigcn:Tooltip>
            <twig:Twigcn:Tooltip text="Tooltip on right" side="right">
                <twig:Twigcn:Button variant="outline">Right</twig:Twigcn:Button>
            </twig:Twigcn:Tooltip>
        </section>
    </section>

    {# Alignment #}
    <section class="card">
        <header>
            <h2 class="text-lg font-semibold">Alignment</h2>
        </header>
        <section class="flex flex-wrap gap-4 py-8">
            <twig:Twigcn:Tooltip text="Aligned to start" side="top" align="start">
                <twig:Twigcn:Button variant="outline">Start</twig:Twigcn:Button>
            </twig:Twigcn:Tooltip>
            <twig:Twigcn:Tooltip text="Aligned to center" side="top" align="center">
                <twig:Twigcn:Button variant="outline">Center</twig:Twigcn:Button>
            </twig:Twigcn:Tooltip>
            <twig:Twigcn:Tooltip text="Aligned to end" side="top" align="end">
                <twig:Twigcn:Button variant="outline">End</twig:Twigcn:Button>
            </twig:Twigcn:Tooltip>
        </section>
    </section>

    {# With Icons #}
    <section class="card">
        <header>
            <h2 class="text-lg font-semibold">With Icon Buttons</h2>
        </header>
        <section class="flex flex-wrap gap-4">
            <twig:Twigcn:Tooltip text="Add item">
                <twig:Twigcn:Button :iconOnly="true" variant="outline">
                    <twig:ux:icon name="lucide:plus" />
                </twig:Twigcn:Button>
            </twig:Twigcn:Tooltip>
            <twig:Twigcn:Tooltip text="Edit">
                <twig:Twigcn:Button :iconOnly="true" variant="outline">
                    <twig:ux:icon name="lucide:pencil" />
                </twig:Twigcn:Button>
            </twig:Twigcn:Tooltip>
            <twig:Twigcn:Tooltip text="Delete">
                <twig:Twigcn:Button :iconOnly="true" variant="outline">
                    <twig:ux:icon name="lucide:trash" />
                </twig:Twigcn:Button>
            </twig:Twigcn:Tooltip>
            <twig:Twigcn:Tooltip text="Settings">
                <twig:Twigcn:Button :iconOnly="true" variant="outline">
                    <twig:ux:icon name="lucide:settings" />
                </twig:Twigcn:Button>
            </twig:Twigcn:Tooltip>
        </section>
    </section>

    {# Usage #}
    <section class="card">
        <header>
            <h2 class="text-lg font-semibold">Usage</h2>
        </header>
        <section class="prose prose-sm max-w-none">
            <pre class="bg-muted p-4 rounded-lg overflow-x-auto"><code>&lt;twig:Tooltip text="Add to library"&gt;
    &lt;twig:Button variant="outline"&gt;Hover me&lt;/twig:Button&gt;
&lt;/twig:Tooltip&gt;

{# Different positions #}
&lt;twig:Tooltip text="..." side="bottom"&gt;...&lt;/twig:Tooltip&gt;
&lt;twig:Tooltip text="..." side="left"&gt;...&lt;/twig:Tooltip&gt;
&lt;twig:Tooltip text="..." side="right"&gt;...&lt;/twig:Tooltip&gt;

{# Alignment #}
&lt;twig:Tooltip text="..." side="top" align="start"&gt;...&lt;/twig:Tooltip&gt;
&lt;twig:Tooltip text="..." side="top" align="end"&gt;...&lt;/twig:Tooltip&gt;</code></pre>
        </section>
    </section>
</div>
{% endblock %}
