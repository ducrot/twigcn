{% extends 'base.html.twig' %}

{% block title %}twigcn/ui + TwigcnBundle Demo{% endblock %}

{% block content %}
<div class="flex flex-col items-center gap-4 text-center xl:gap-6">
    <h1 class="flex flex-col items-center gap-2  max-w-4xl">
        <span class="text-primary leading-tighter text-4xl font-semibold tracking-tight text-balance xl:text-5xl xl:tracking-tight">Twig UI Components</span>
        <span class="text-xl font-semibold">shadcn/ui + Basecoat inspired</span>
    </h1>
    <p class="text-foreground max-w-xl text-lg text-balance">
        A Twig UI component library built with Tailwind CSS that works with Symfony UX.
    </p>

    <div class="mt-8 flex justify-center gap-4">
        <twig:Twigcn:Button :as="'a'" href="{{ path('app_getting_started') }}" size="lg">
            <twig:ux:icon name="lucide:rocket" class="size-4" />
            Get Started
        </twig:Twigcn:Button>
        <twig:Twigcn:Button :as="'a'" href="{{ path('showcase_index') }}" variant="outline" size="lg">
            <twig:ux:icon name="lucide:component" class="size-4" />
            View Components
        </twig:Twigcn:Button>
    </div>
</div>
{% endblock %}
