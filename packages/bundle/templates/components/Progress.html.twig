<div
    role="progressbar"
    aria-valuenow="{{ value }}"
    aria-valuemin="0"
    aria-valuemax="{{ max }}"
    class="{{ this.progressClasses }}"
    {{ attributes }}
>
    <div
        class="h-full w-full flex-1 bg-primary transition-all"
        style="transform: translateX(-{{ 100 - this.percentage }}%)"
    ></div>
</div>
