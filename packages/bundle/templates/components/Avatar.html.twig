<span class="{{ this.avatarClasses }}" {{ attributes }}>
    {% if src %}
        <img src="{{ src }}" alt="{{ alt }}" class="aspect-square h-full w-full object-cover">
    {% else %}
        <span class="flex h-full w-full items-center justify-center rounded-full bg-muted text-muted-foreground text-sm font-medium">
            {{ this.fallbackInitials }}
        </span>
    {% endif %}
</span>
