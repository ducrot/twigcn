<div class="{{ this.emptyClasses }}" {{ attributes }}>
    {% if icon %}
        <div class="flex items-center justify-center size-12 rounded-full bg-muted mb-4">
            <twig:ux:icon name="{{ icon }}" class="size-6 text-muted-foreground" />
        </div>
    {% endif %}
    {% if title %}
        <h3 class="text-lg font-semibold">{{ title }}</h3>
    {% endif %}
    {% if description %}
        <p class="text-muted-foreground text-sm mt-1 max-w-sm">{{ description }}</p>
    {% endif %}
    {% block content %}{% endblock %}
</div>
