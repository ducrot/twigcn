<twig:Twigcn:CommandItem :value="value" class="combobox-item {{ class }}" data-action="click->combobox#select" data-combobox-value-param="{{ value }}" data-combobox-label-param="{{ label }}">
    {{ label }}
    <twig:ux:icon name="lucide:check" class="w-4 h-4 ml-auto {{ selected ? 'opacity-100' : 'opacity-0' }}" />
</twig:Twigcn:CommandItem>
