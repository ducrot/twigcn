<aside
    data-controller="sidebar"
    data-sidebar-collapsible-value="{{ collapsible }}"
    data-slot="sidebar"
    data-side="{{ side }}"
    data-variant="{{ variant }}"
    data-collapsible="{{ collapsible }}"
    data-state="{{ this.initialState }}"
    aria-hidden="{{ this.initialState == 'collapsed' ? 'true' : 'false' }}"
    class="{{ this.sidebarClasses }}"
    {{ attributes }}
>
    <nav>
        {% block content %}{% endblock %}
    </nav>
</aside>
